{
    "name": "doppelimpacttest/doppel-sdk",
    "description": "Official Doppel PHP SDK — capture LLM calls and forward them to Doppel.",
    "type": "library",
    "license": "MIT",
    "keywords": ["doppel", "sdk", "llm", "shadow", "testing"],
    "homepage": "https://github.com/doppelimpacttest/doppel-php",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": { "Doppel\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Doppel\\Tests\\": "tests/" }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
